          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  ROUND((\n    COALESCE(SUM((d.start_ideal_range_km - d.end_ideal_range_km) * c.efficiency), 0)\n    / NULLIF(convert_km(SUM(d.distance)::numeric, '$length_unit'), 0)\n    * 1000\n  )::numeric, 1) AS avg_wh_per_unit\nFROM drives d\nJOIN cars c ON c.id = d.car_id\nWHERE d.car_id = $car_id\n  AND d.end_date IS NOT NULL\n  AND EXTRACT(YEAR FROM (d.start_date AT TIME ZONE 'UTC' AT TIME ZONE 'Asia/Shanghai')) = $year::int\n  AND d.distance > 0\n  AND d.start_ideal_range_km > d.end_ideal_range_km;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
