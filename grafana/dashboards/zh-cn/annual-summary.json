        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH months AS (\n  SELECT generate_series(1, 12) AS month\n),\nt AS (\n  SELECT\n    EXTRACT(MONTH FROM (start_date AT TIME ZONE 'UTC' AT TIME ZONE 'Asia/Shanghai'))::int AS month,\n    effective_cost(id, cost) AS cost\n  FROM charging_processes\n  WHERE car_id = $car_id\n    AND end_date IS NOT NULL\n    AND effective_cost(id, cost) IS NOT NULL\n    AND EXTRACT(YEAR FROM (start_date AT TIME ZONE 'UTC' AT TIME ZONE 'Asia/Shanghai')) = $year::int\n)\nSELECT\n  make_date($year::int, months.month, 1) AS time,\n  ROUND(COALESCE(SUM(t.cost), 0)::numeric, 2) AS \"充电费用\"\nFROM months\nLEFT JOIN t ON t.month = months.month\nGROUP BY months.month\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "月度充电费用趋势",
      "type": "timeseries"
    },
