          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(g.name, a.display_name, CONCAT(d.car_id, ' trip')) AS address,\n  COUNT(*) AS visit_count,\n  ROUND(convert_km(SUM(d.distance)::numeric, '$length_unit'), 0) AS total_km\nFROM drives d\nLEFT JOIN addresses a ON d.end_address_id = a.id\nLEFT JOIN geofences g ON d.end_geofence_id = g.id\nWHERE d.car_id = $car_id\n  AND d.end_date IS NOT NULL\n  AND EXTRACT(YEAR FROM (d.start_date AT TIME ZONE 'UTC' AT TIME ZONE 'Asia/Shanghai')) = $year::int\n  AND (g.name IS NOT NULL OR a.display_name IS NOT NULL)\nGROUP BY 1\nORDER BY visit_count DESC\nLIMIT 10;",
