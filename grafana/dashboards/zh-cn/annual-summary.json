          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  TO_CHAR(date_trunc('month', (start_date AT TIME ZONE 'UTC' AT TIME ZONE 'Asia/Shanghai')), 'MM月') AS month,\n  ROUND(convert_km(COALESCE(SUM(distance), 0)::numeric, '$length_unit'), 0) AS \"月度里程\"\nFROM drives\nWHERE car_id = $car_id\n  AND end_date IS NOT NULL\n  AND EXTRACT(YEAR FROM (start_date AT TIME ZONE 'UTC' AT TIME ZONE 'Asia/Shanghai')) = $year::int\nGROUP BY date_trunc('month', (start_date AT TIME ZONE 'UTC' AT TIME ZONE 'Asia/Shanghai'))\nORDER BY date_trunc('month', (start_date AT TIME ZONE 'UTC' AT TIME ZONE 'Asia/Shanghai'));",
          "refId": "A",
