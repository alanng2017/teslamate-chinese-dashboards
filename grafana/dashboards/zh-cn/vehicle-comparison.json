      "title": "综合对比一览表",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH drive_scope AS (\n  SELECT\n    d.car_id,\n    d.distance,\n    (d.start_ideal_range_km - d.end_ideal_range_km) * c.efficiency AS energy_kwh,\n    d.distance > 0 AND d.start_ideal_range_km > d.end_ideal_range_km AS energy_valid\n  FROM drives d\n  JOIN cars c ON c.id = d.car_id\n  WHERE d.end_date IS NOT NULL\n    AND $__timeFilter(d.start_date)\n),\ndrive_stats AS (\n  SELECT\n    car_id,\n    convert_km(COALESCE(SUM(distance), 0)::numeric, '$length_unit') AS total_distance_raw,\n    ROUND(convert_km(COALESCE(SUM(distance), 0)::numeric, '$length_unit'), 0) AS total_distance_display,\n    COUNT(*) AS drive_count,\n    ROUND(convert_km(COALESCE(SUM(distance) FILTER (WHERE energy_valid), 0)::numeric, '$length_unit'), 0) AS energy_sample_distance,\n    ROUND((SUM(energy_kwh) FILTER (WHERE energy_valid) / NULLIF(convert_km((SUM(distance) FILTER (WHERE energy_valid))::numeric, '$length_unit'), 0) * 1000)::numeric, 1) AS avg_consumption\n  FROM drive_scope\n  GROUP BY car_id\n),\ncp_stats AS (\n  SELECT cp.car_id,\n    ROUND(SUM(effective_cost(cp.id, cp.cost))::numeric, 2) AS total_cost,\n    ROUND(\n      (COUNT(DISTINCT CASE\n        -- 可复议默认值: 中国/特斯拉场景下 >22kW 作为直流快充保守代理；22kW 本身可能仍是交流/边界值。\n        WHEN fast.max_power > 22 THEN cp.id\n      END)::numeric /\n       NULLIF(COUNT(DISTINCT cp.id), 0) * 100)::numeric, 1\n    ) AS dc_ratio\n  FROM charging_processes cp\n  LEFT JOIN LATERAL (\n    SELECT MAX(charger_power) AS max_power FROM charges WHERE charging_process_id = cp.id\n  ) fast ON true\n  WHERE cp.end_date IS NOT NULL\n    AND $__timeFilter(cp.start_date)\n  GROUP BY cp.car_id\n)\nSELECT\n  COALESCE(c.name, CONCAT('VIN ', RIGHT(c.vin, 6))) AS \"车辆\",\n  COALESCE(d_stats.total_distance_display, 0) AS \"总里程($length_unit)\",\n  COALESCE(d_stats.drive_count, 0) AS \"行程次数\",\n  d_stats.avg_consumption AS \"平均能耗(Wh/$length_unit)\",\n  COALESCE(d_stats.energy_sample_distance, 0) AS \"能耗样本里程($length_unit)\",\n  COALESCE(cp_stats.total_cost, 0) AS \"总充电费用(元)\",\n  ROUND((cp_stats.total_cost / NULLIF(d_stats.total_distance_raw, 0))::numeric, 4) AS \"单位里程电费(元/$length_unit)\",\n  COALESCE(cp_stats.dc_ratio, 0) AS \"快充比例(%)\"\nFROM cars c\nLEFT JOIN drive_stats d_stats ON d_stats.car_id = c.id\nLEFT JOIN cp_stats ON cp_stats.car_id = c.id\nORDER BY COALESCE(d_stats.total_distance_raw, 0) DESC;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ]
    },
