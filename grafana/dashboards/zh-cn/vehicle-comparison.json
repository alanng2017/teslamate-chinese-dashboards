          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH energy_drives AS (\n  SELECT\n    d.car_id,\n    d.distance,\n    (d.start_ideal_range_km - d.end_ideal_range_km) * c.efficiency AS energy_kwh\n  FROM drives d\n  JOIN cars c ON c.id = d.car_id\n  WHERE d.end_date IS NOT NULL\n    AND d.distance > 0\n    AND d.start_ideal_range_km > d.end_ideal_range_km\n    AND $__timeFilter(d.start_date)\n)\nSELECT\n  COALESCE(c.name, CONCAT('VIN ', RIGHT(c.vin, 6))) AS \"车辆\",\n  ROUND((SUM(ed.energy_kwh) / NULLIF(convert_km(SUM(ed.distance)::numeric, '$length_unit'), 0) * 1000)::numeric, 1) AS \"平均能耗(Wh/$length_unit)\"\nFROM cars c\nLEFT JOIN energy_drives ed ON ed.car_id = c.id\nGROUP BY c.id, c.name, c.vin\nHAVING SUM(ed.distance) > 0\nORDER BY \"平均能耗(Wh/$length_unit)\" ASC NULLS LAST;",
