      "title": "各车电池健康度(%)",
      "type": "bargauge",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH charge_samples AS (\n  SELECT\n    cp.car_id,\n    cp.end_date,\n    c.date,\n    c.rated_battery_range_km * (cars.efficiency * 100) / NULLIF(c.usable_battery_level, 0) AS capacity\n  FROM charging_processes cp\n  INNER JOIN (\n    SELECT charging_process_id, MAX(date) AS last_date\n    FROM charges\n    WHERE usable_battery_level >= 80 -- 可复议默认值: 复用续航退化 SOC >=80% 高质量样本口径，理想门槛 >=90%。\n    GROUP BY charging_process_id\n  ) gcharges ON cp.id = gcharges.charging_process_id\n  INNER JOIN charges c ON c.charging_process_id = cp.id AND c.date = gcharges.last_date\n  INNER JOIN cars ON cars.id = cp.car_id\n  WHERE cp.end_date IS NOT NULL\n    AND cp.charge_energy_added >= cars.efficiency * 100 -- 可复议默认值: 排除小补电样本。\n    AND c.usable_battery_level >= 80 -- 可复议默认值: 复用续航退化 SOC >=80% 高质量样本口径，理想门槛 >=90%。\n),\nmax_cap AS (\n  SELECT car_id, MAX(capacity) AS capacity\n  FROM charge_samples\n  GROUP BY car_id\n),\ncur_cap AS (\n  SELECT car_id, AVG(capacity) AS capacity\n  FROM (\n    SELECT\n      car_id,\n      capacity,\n      ROW_NUMBER() OVER (PARTITION BY car_id ORDER BY end_date DESC, date DESC) AS rn\n    FROM charge_samples\n  ) t\n  WHERE rn <= 100\n  GROUP BY car_id\n)\nSELECT\n  COALESCE(cars.name, CONCAT('VIN ', RIGHT(cars.vin, 6))) AS \"车辆\",\n  ROUND(LEAST(100, cur_cap.capacity / NULLIF(max_cap.capacity, 0) * 100)::numeric, 1) AS \"电池健康度(%)\"\nFROM cars\nLEFT JOIN max_cap ON max_cap.car_id = cars.id\nLEFT JOIN cur_cap ON cur_cap.car_id = cars.id\nORDER BY \"电池健康度(%)\" DESC NULLS LAST;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
