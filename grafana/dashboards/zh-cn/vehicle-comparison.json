          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(c.name, CONCAT('VIN ', RIGHT(c.vin, 6))) AS \"车辆\",\n  COUNT(d.id) AS \"行程次数\"\nFROM cars c\nLEFT JOIN drives d ON d.car_id = c.id AND d.end_date IS NOT NULL AND $__timeFilter(d.start_date)\nGROUP BY c.id, c.name, c.vin\nORDER BY \"行程次数\" DESC;",
