          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('day', date) AS time,\n  COUNT(*) FILTER (WHERE sentry_mode = true) AS \"哨兵模式记录点\"\nFROM positions\nWHERE car_id = $car_id\n  AND $__timeFilter(date)\nGROUP BY 1\nHAVING COUNT(*) FILTER (WHERE sentry_mode = true) > 0\nORDER BY 1;",
