          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('month', start_date) AS time,\n  ROUND(SUM(EXTRACT(EPOCH FROM (end_date - start_date))) / 3600.0)::numeric AS \"哨兵时长(小时)\"\nFROM states\nWHERE car_id = $car_id\n  AND state = 'sentry'\n  AND $__timeFilter(start_date)\nGROUP BY 1\nORDER BY 1;",
