      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "TeslaMate"},
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('month', start_date) AS time,\n  ROUND(AVG(\n    GREATEST(start_battery_level - end_battery_level, 0)\n  )::numeric, 2) AS \"月均停车SOC损失(%)\"\nFROM (\n  SELECT start_date, start_battery_level, end_battery_level\n  FROM drives\n  WHERE car_id = $car_id AND $__timeFilter(start_date)\n    AND start_battery_level > end_battery_level\n  UNION ALL\n  SELECT start_date,\n    LAG(end_battery_level) OVER (ORDER BY start_date) AS start_battery_level,\n    start_battery_level AS end_battery_level\n  FROM drives\n  WHERE car_id = $car_id AND $__timeFilter(start_date)\n) intervals\nWHERE start_battery_level IS NOT NULL\nGROUP BY 1\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "月度停车掉电趋势（平均行程中SOC损失%）",
      "type": "timeseries"
    },
