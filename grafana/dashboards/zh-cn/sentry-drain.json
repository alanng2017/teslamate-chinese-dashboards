      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "TeslaMate"},
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH parking AS (\n  SELECT\n    v.start_date AS park_start,\n    v.end_date AS park_end,\n    lag(t.end_battery_level) OVER w AS start_soc,\n    t.start_battery_level AS end_soc,\n    EXTRACT(EPOCH FROM age(t.start_date, lag(t.end_date) OVER w)) / 3600.0 AS park_hours\n  FROM (\n    SELECT start_date, end_date, end_battery_level, start_battery_level\n    FROM (\n      SELECT start_date, end_date, end_battery_level, start_battery_level FROM drives WHERE car_id = $car_id\n      UNION ALL\n      SELECT start_date, end_date, end_battery_level, start_battery_level FROM charging_processes WHERE car_id = $car_id\n    ) all_events\n    ORDER BY start_date\n  ) t,\n  LATERAL (\n    SELECT lag(t.end_date) OVER w AS prev_end\n    FROM (SELECT end_date FROM drives WHERE car_id=$car_id UNION ALL SELECT end_date FROM charging_processes WHERE car_id=$car_id) sq\n    WINDOW w AS (ORDER BY end_date)\n    LIMIT 1\n  ) v\n  WINDOW w AS (ORDER BY t.start_date)\n)\nSELECT\n  date_trunc('month', park_start) AS time,\n  ROUND(AVG(GREATEST(start_soc - end_soc, 0))::numeric, 2) AS \"月均停车SOC损失(%)\"\nFROM parking\nWHERE $__timeFilter(park_start)\n  AND park_hours >= 1\n  AND start_soc IS NOT NULL\n  AND start_soc > end_soc\nGROUP BY 1\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "月度停车掉电趋势（平均每次停车SOC损失%）",
      "type": "timeseries"
    },
