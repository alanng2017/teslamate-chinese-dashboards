          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  ROUND((\n    COUNT(*) FILTER (WHERE sentry_mode = true)::numeric\n    / NULLIF(COUNT(DISTINCT DATE(date)), 0)\n  ), 1) AS avg_per_day\nFROM positions\nWHERE car_id = $car_id\n  AND $__timeFilter(date);",
