          {"matcher": {"id": "byName", "options": "avg_hours"}, "properties": [{"id": "displayName", "value": "平均单次时长"}, {"id": "unit", "value": "h"}, {"id": "decimals", "value": 1}]},
          {"matcher": {"id": "byName", "options": "est_kwh"}, "properties": [{"id": "displayName", "value": "估算耗电(kWh)"}, {"id": "unit", "value": "kwatth"}, {"id": "decimals", "value": 1}]}
        ]
