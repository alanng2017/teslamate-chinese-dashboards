      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "哨兵记录点数"}]
      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "TeslaMate"},
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(a.display_name, CONCAT(ROUND(p.latitude::numeric, 3), ', ', ROUND(p.longitude::numeric, 3))) AS address,\n  COUNT(*) AS sentry_count,\n  COUNT(DISTINCT DATE(p.date)) AS day_count,\n  MAX(p.date) AS last_seen\nFROM positions p\nLEFT JOIN drives d ON d.end_position_id = p.id\nLEFT JOIN addresses a ON d.end_address_id = a.id\nWHERE p.car_id = $car_id\n  AND p.sentry_mode = true\n  AND $__timeFilter(p.date)\nGROUP BY 1\nORDER BY sentry_count DESC\nLIMIT 20;",
          "refId": "A",
          "sql": {"columns": [{"parameters": [], "type": "function"}], "groupBy": [{"property": {"type": "string"}, "type": "groupBy"}], "limit": 50}
        }
      ],
      "title": "哨兵模式常驻地点 TOP20（记录点越多停留越久）",
      "type": "table"
    }
