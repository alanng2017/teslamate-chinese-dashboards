      "pluginVersion": "11.6.1",
      "description": "选定时间范围内，哨兵模式日均开启时长。哨兵模式会消耗约15-20W功率。",
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "TeslaMate"},
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  ROUND((\n    COALESCE(SUM(EXTRACT(EPOCH FROM (end_date - start_date))), 0)\n    / 3600.0\n    / NULLIF(EXTRACT(DAY FROM (MAX(end_date) - MIN(start_date))), 0)\n  )::numeric, 1) AS avg_hours_per_day\nFROM states\nWHERE car_id = $car_id\n  AND state = 'sentry'\n  AND $__timeFilter(start_date);",
          "refId": "A",
          "sql": {"columns": [{"parameters": [], "type": "function"}], "groupBy": [{"property": {"type": "string"}, "type": "groupBy"}], "limit": 50}
        }
      ],
