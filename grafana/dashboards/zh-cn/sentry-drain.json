      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 24},
      "id": 7,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "哨兵触发次数"}]
      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "TeslaMate"},
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(a.display_name, CONCAT(ROUND(p.latitude::numeric,4), ',', ROUND(p.longitude::numeric,4))) AS address,\n  COUNT(*) AS sentry_count,\n  ROUND(SUM(EXTRACT(EPOCH FROM (s.end_date - s.start_date))) / 3600.0)::numeric AS total_hours,\n  ROUND(AVG(EXTRACT(EPOCH FROM (s.end_date - s.start_date))) / 3600.0)::numeric AS avg_hours,\n  ROUND((SUM(EXTRACT(EPOCH FROM (s.end_date - s.start_date))) / 3600.0 * 0.015)::numeric, 1) AS est_kwh\nFROM states s\nJOIN positions p ON p.car_id = s.car_id\n  AND p.date >= s.start_date\n  AND p.date <= s.end_date\nLEFT JOIN addresses a ON p.address_id = a.id\nWHERE s.car_id = $car_id\n  AND s.state = 'sentry'\n  AND $__timeFilter(s.start_date)\nGROUP BY 1\nORDER BY sentry_count DESC\nLIMIT 20;",
          "refId": "A",
          "sql": {"columns": [{"parameters": [], "type": "function"}], "groupBy": [{"property": {"type": "string"}, "type": "groupBy"}], "limit": 50}
        }
      ],
      "title": "哨兵模式触发地点统计 TOP20",
      "type": "table"
    }
